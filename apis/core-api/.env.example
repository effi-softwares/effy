# core-api configuration — NAMES ONLY, never commit real values (.env is gitignored).
# Local runs: `make core-run` composes DB_DSN and the AUTH_* values from the platform
# contract (SSM + Secrets Manager) at invocation and injects them as process env —
# you normally do NOT need a .env file at all.

EFFY_ENV=dev
PORT=8080

# libpq keyword-format DSN. Composed by infra/scripts/db-dsn.sh — never written to disk.
DB_DSN=

AWS_REGION=ap-southeast-2

# Customer pool (SSM: /effy/<env>/auth/customer/{user_pool_id,app_client_id})
AUTH_CUSTOMER_POOL_ID=
AUTH_CUSTOMER_CLIENT_ID=

# Comma-separated approved browser origins for this environment.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# 019 commerce — product media bucket (SSM: /effy/<env>/media/bucket, from 016).
AWS_MEDIA_BUCKET=

# 019 commerce — Stripe (test mode). SECRET + webhook secret ONLY; never a client key.
# Fetched by `make core-run` from Secrets Manager (/effy/<env>/stripe/{secret_key,webhook_secret}).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

LOG_LEVEL=info
