# Back-office web config (VITE_*, build-time, NON-SECRET) — contracts/config.contract.md.
# Copy to .env.local and fill from the 001/004 contract. NEVER commit real values.
VITE_COGNITO_USER_POOL_ID=   # ssm /effy/dev/auth/back-office/user_pool_id
VITE_COGNITO_CLIENT_ID=      # ssm /effy/dev/auth/back-office/app_client_id
VITE_API_BASE_URL=           # shared edge gateway host — SSM /effy/dev/edge/api_endpoint (A3); paths carry /admin/v1/...
# Optional telemetry — degrades to a no-op when absent.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
