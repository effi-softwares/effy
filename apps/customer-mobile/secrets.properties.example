# customer-mobile — build-time configuration (013 FR-039..FR-042)
#
# Copy to `secrets.properties` (git-ignored) and fill from `make output ENV=dev`
# or SSM: /effy/<env>/auth/customer/*  and  /effy/<env>/edge/api_endpoint.
#
# NONE of these is a secret. A user-pool id and an app-client id are NAMES, not keys — they identify
# WHICH pool to talk to and authorize nothing. The app client has NO client secret
# (generate_secret = false), so there is nothing here an attacker who reads the binary could use.
# A build with any value missing FAILS at configuration time, naming what is missing.
#
# Environment variables of the same name WIN over this file, so CI needs no checked-in file.

COGNITO_USER_POOL_ID=ap-southeast-2_xxxxxxxxx
# ⚠ the MOBILE app client (90-day session): output `customer_mobile_app_client_id`
#   / SSM /effy/<env>/auth/customer/mobile_app_client_id. NOT the web `app_client_id`.
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=ap-southeast-2
EDGE_API_BASE_URL=https://edge-api.dev.effyshopping.com
CORE_API_BASE_URL=http://localhost:8080
