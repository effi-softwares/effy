{
  "name": "@effy/customer-web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Effy customer storefront \u2014 the platform's first PUBLIC surface (specs/011-customer-storefront-web). Next.js 16 App Router, SSR-first, guest-first, SEO-bearing. LOCAL-ONLY this slice (no hosted deploy).",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "playwright test",
    "depcruise": "depcruise app components lib --config .dependency-cruiser.cjs",
    "size": "node scripts/bundle-budget.mjs",
    "analyze": "next experimental-analyze"
  },
  "dependencies": {
    "@aws-amplify/adapter-nextjs": "^1.7.3",
    "@effy/api-client": "workspace:*",
    "@effy/design-system": "workspace:*",
    "@effy/shared-types": "workspace:*",
    "aws-amplify": "^6.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.200.0",
    "radix-ui": "^1.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.6.0",
    "dependency-cruiser": "^16.0.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4",
    "typescript": "~5.9.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.0"
  }
}
