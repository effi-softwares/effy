# shop-mobile — build-time configuration (014 FR-033..FR-036). Copy to secrets.properties (git-ignored).
# NONE is a secret: a pool id / app-client id is a NAME, not a key; the client has no client secret.
# Fill from `make output ENV=dev` / SSM /effy/<env>/auth/shop/* + /effy/<env>/edge/api_endpoint.

COGNITO_USER_POOL_ID=ap-southeast-2_xxxxxxxxx
# ⚠ the SHOP MOBILE client — output `shop_mobile_app_client_id` / SSM .../auth/shop/mobile_app_client_id.
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=ap-southeast-2
SHOP_API_BASE_URL=https://edge-api.dev.effyshopping.com
