{
  "name": "@effy/design-system",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "description": "Effy web design system — the brand SSOT (Effy Emerald #065f46 accent + terracotta #d0735a over neutral surfaces, Nunito Sans type, spacing/radius scales) + Tailwind v4 theme tokens + dark mode + cn util + the platform's one set of shadcn/ui primitives (constitution Principle V). Internal package: exports TS source + CSS.",
  "exports": {
    ".": "./src/index.ts",
    "./ui": "./src/ui/index.ts",
    "./hooks/use-mobile": "./src/hooks/use-mobile.ts",
    "./tokens.css": "./src/tokens.css"
  },
  "types": "./src/index.ts",
  "scripts": {
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/check-tokens.mjs",
    "tokens:test": "node scripts/check-tokens.mjs",
    "tokens:gen": "node scripts/gen-compose-theme.mjs",
    "tokens:check": "node scripts/check-compose-theme.mjs"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "radix-ui": "^1.6.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "~5.9.2"
  }
}
