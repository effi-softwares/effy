    "AttributeAllowedValueDTO": {
      "additionalProperties": false,
      "description": "An option for a select-typed attribute.",
      "properties": {
        "displayOrder": {
          "type": "number"
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
