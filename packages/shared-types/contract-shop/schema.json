          "type": "array"
        },
        "brand": {
          "type": [
            "string",
            "null"
          ]
        },
        "categoryName": {
          "type": "string"
        },
        "compareAtAmount": {
          "type": [
            "string",
            "null"
          ]
        },
        "createdAt": {
          "type": "string"
        },
        "currency": {
          "type": "string"
        },
        "gtin": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "longDescription": {
          "type": [
            "string",
            "null"
          ]
