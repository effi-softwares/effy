    "CreateProductRequest": {
      "additionalProperties": false,
      "description": "POST /shop/v1/products — create a shop-owned product. `brand` is a first-class column (FR-010a).",
      "properties": {
        "attributes": {
          "items": {
            "$ref": "#/definitions/AttributeValueInputDTO"
          },
          "type": "array"
        },
        "brand": {
          "type": [
            "string",
            "null"
          ]
        },
        "compareAtAmount": {
          "type": [
            "string",
            "null"
          ]
        },
        "gtin": {
          "type": [
            "string",
            "null"
          ]
        },
        "longDescription": {
          "type": [
            "string",
            "null"
          ]
        },
        "media": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "altText": {
                "type": [
                  "string",
                  "null"
