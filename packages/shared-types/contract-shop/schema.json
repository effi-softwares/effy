        "value": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "value",
        "label",
        "displayOrder"
      ],
      "type": "object"
    },
    "AttributeDataType": {
      "description": "The data type of a back-office-authored attribute — drives the form input + value column.",
      "enum": [
        "short_text",
        "long_text",
        "number",
        "boolean",
        "single_select",
        "multi_select"
      ],
      "type": "string"
    },
    "AttributeValidationDTO": {
      "additionalProperties": false,
      "description": "Optional per-attribute validation envelope (jsonb `validation`). All fields optional.",
      "properties": {
        "max": {
          "type": [
            "number",
            "null"
          ]
        },
        "maxLength": {
          "type": [
            "number",
            "null"
          ]
        },
        "min": {
          "type": [
            "number",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "AttributeValueInputDTO": {
      "additionalProperties": false,
      "description": "A value supplied for one attribute on create/edit (only the field matching the data type is set).",
      "properties": {
        "attributeId": {
          "type": "string"
        },
        "valueBoolean": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "valueNumber": {
          "type": [
            "number",
            "null"
          ]
        },
        "valueOptions": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ]
        },
        "valueText": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "attributeId"
      ],
      "type": "object"
    },
    "CatalogSchemaDTO": {
      "additionalProperties": false,
      "description": "One call bootstraps the create form: the active types (each with their assigned attributes) and the active category tree (flat, parentId-linked).",
