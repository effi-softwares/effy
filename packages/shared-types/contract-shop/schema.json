          "type": "string"
        },
        "longDescription": {
          "type": [
            "string",
            "null"
          ]
        },
        "media": {
          "items": {
            "$ref": "#/definitions/ProductMediaDTO"
          },
          "type": "array"
        },
        "missingMandatoryAttributes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "name": {
          "type": "string"
