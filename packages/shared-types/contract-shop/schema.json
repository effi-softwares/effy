        "detail": {
          "type": "string"
        },
        "instance": {
          "type": "string"
        },
        "status": {
          "type": "number"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "title",
        "status"
      ],
      "type": "object"
    },
    "ProductAttributeValueDTO": {
      "additionalProperties": false,
      "description": "A typed attribute value on a product (EAV, one value shape per data type).",
      "properties": {
        "attributeId": {
          "type": "string"
        },
        "dataType": {
          "$ref": "#/definitions/AttributeDataType"
        },
        "key": {
