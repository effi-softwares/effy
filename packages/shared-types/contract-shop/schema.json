          "type": "string"
        },
        "productTypeId": {
          "type": "string"
        },
        "sections": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "shopId": {
          "type": "string"
        },
        "shortDescription": {
          "type": "string"
        },
        "sku": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/definitions/ProductStatus"
        },
        "typeName": {
          "type": "string"
        },
