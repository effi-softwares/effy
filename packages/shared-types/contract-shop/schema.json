        "priceAmount": {
          "type": "string"
        },
        "primaryCategoryId": {
          "type": "string"
        },
        "primaryMediaStorageKey": {
          "type": [
            "string",
            "null"
          ]
        },
        "productTypeId": {
          "type": "string"
        },
        "sectionIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "shortDescription": {
          "type": "string"
        },
        "sku": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "productTypeId",
        "primaryCategoryId",
        "name",
        "priceAmount",
        "shortDescription"
      ],
      "type": "object"
    },
    "CreateShopSectionRequest": {
      "additionalProperties": false,
