{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "AddToCartRequest": {
      "additionalProperties": false,
      "description": "POST /v1/cart/items — add or increment a line.",
      "properties": {
        "productId": {
          "type": "string"
        },
        "quantity": {
          "type": "number"
        }
      },
      "required": [
        "productId",
        "quantity"
      ],
      "type": "object"
    },
    "AddressDTO": {
      "additionalProperties": false,
      "description": "A saved delivery address (GET /v1/addresses).",
      "properties": {
        "city": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "isDefault": {
          "type": "boolean"
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        },
        "line1": {
          "type": "string"
        },
        "line2": {
          "type": [
            "string",
            "null"
          ]
        },
        "phone": {
          "type": [
            "string",
            "null"
          ]
        },
        "postalCode": {
          "type": "string"
        },
        "recipientName": {
          "type": "string"
        },
        "region": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "id",
        "label",
        "recipientName",
        "phone",
        "line1",
        "line2",
        "city",
        "region",
        "postalCode",
        "country",
        "isDefault"
      ],
      "type": "object"
    },
    "BannerDTO": {
      "additionalProperties": false,
      "description": "A promotional hero banner. Minimal/derived in this slice (no CMS).",
      "properties": {
        "href": {
          "type": [
            "string",
            "null"
          ]
        },
        "imageUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "key": {
          "type": "string"
        },
        "subtitle": {
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "key",
        "title",
        "subtitle",
        "imageUrl",
        "href"
      ],
      "type": "object"
    },
    "CartDTO": {
      "additionalProperties": false,
      "description": "The full cart (GET /v1/cart and every mutating response).",
      "properties": {
        "currency": {
          "type": "string"
        },
        "deliveryFeeAmount": {
          "type": "string"
        },
        "grandTotalAmount": {
          "type": "string"
        },
        "itemSubtotalAmount": {
          "type": "string"
        },
        "lines": {
          "items": {
            "$ref": "#/definitions/CartLineDTO"
          },
          "type": "array"
        },
        "notices": {
          "items": {
            "$ref": "#/definitions/CartNoticeDTO"
          },
          "type": "array"
        }
      },
      "required": [
        "lines",
        "itemSubtotalAmount",
        "deliveryFeeAmount",
        "grandTotalAmount",
        "currency",
        "notices"
      ],
      "type": "object"
    },
    "CartLineDTO": {
      "additionalProperties": false,
      "description": "A cart line (re-priced against the catalog on every read).",
      "properties": {
        "available": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "imageUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "lineSubtotalAmount": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "packageKey": {
          "description": "OPAQUE package grouping key (021). Items sharing a packageKey ship together as one anonymous \"package\" (one per fulfilling shop). It is NOT a shop id, name, or location — a meaningless-to-the- customer token that lets the cart show the split (021 FR-005a) while revealing no shop (SC-006).",
          "type": "string"
        },
        "priceChangedFrom": {
          "description": "When the authoritative price differs from what the client last saw, the prior amount (UX only).",
          "type": [
            "string",
            "null"
          ]
        },
        "productId": {
          "type": "string"
        },
        "quantity": {
          "type": "number"
        },
        "unitPriceAmount": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "productId",
        "name",
        "imageUrl",
        "unitPriceAmount",
        "quantity",
        "lineSubtotalAmount",
        "available",
        "packageKey"
      ],
      "type": "object"
    },
    "CartNoticeDTO": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/definitions/CartNoticeKind"
        },
        "productId": {
          "type": "string"
        }
      },
      "required": [
        "productId",
        "kind"
      ],
      "type": "object"
    },
    "CartNoticeKind": {
      "description": "A cart-level notice surfaced at read/checkout (an item went away or changed price).",
      "enum": [
        "unavailable",
        "price_changed"
      ],
      "type": "string"
    },
    "CheckoutDeliveryMethod": {
      "description": "The three delivery service levels (021). Availability per package follows from the shop's origin zone and the customer's destination zone — never from shop identity, which the customer never sees.",
      "enum": [
        "same_day",
        "scheduled",
        "standard"
      ],
      "type": "string"
    },
    "ConfirmCheckoutRequest": {
      "additionalProperties": false,
      "description": "POST /v1/checkout/confirm — fallback finalizer (covers a delayed/missed webhook).",
      "properties": {
        "orderId": {
          "type": "string"
        }
      },
      "required": [
        "orderId"
      ],
      "type": "object"
    },
    "CreateAddressRequest": {
      "additionalProperties": false,
      "description": "POST /v1/addresses — the first address created becomes the default.",
      "properties": {
        "city": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        },
        "line1": {
          "type": "string"
        },
        "line2": {
          "type": [
            "string",
            "null"
          ]
        },
        "makeDefault": {
          "type": "boolean"
        },
        "phone": {
          "type": [
            "string",
            "null"
          ]
        },
        "postalCode": {
          "type": "string"
        },
        "recipientName": {
          "type": "string"
        },
        "region": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "recipientName",
        "line1",
        "city",
        "postalCode"
      ],
      "type": "object"
    },
    "CreateCheckoutIntentRequest": {
      "additionalProperties": false,
      "description": "POST /v1/checkout/intent — create/locate the pending order and its PaymentIntent (019, extended 021).",
      "properties": {
        "addressId": {
          "description": "The SHIPPING address (required). Serviceability + delivery pricing key off this (021).",
          "type": "string"
        },
        "billingAddressId": {
          "description": "023: the BILLING address, when the customer diverged from shipping. Absent / null / equal to `addressId` → billing is \"same as shipping\" (the order stores NULL). Billing never affects the amount or the quote.",
          "type": [
            "string",
            "null"
          ]
        },
        "excludedPackageKeys": {
          "description": "021: packages the customer confirmed proceeding WITHOUT (auto-set-aside undeliverable items). MUST exactly match the server's unserviceable set or the intent is refused (FR-006b, SC-011a).",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "quoteId": {
          "description": "021: the captured quote being placed. Honored while unexpired; else 409 → re-quote.",
          "type": "string"
        },
        "selections": {
          "description": "021: the customer's per-package method choices (default preference + overrides, resolved).",
          "items": {
            "$ref": "#/definitions/DeliverySelectionDTO"
          },
          "type": "array"
        }
      },
      "required": [
        "addressId"
      ],
      "type": "object"
    },
    "CreateCheckoutIntentResponse": {
      "additionalProperties": false,
      "properties": {
        "clientSecret": {
          "description": "Authorizes confirming exactly this PaymentIntent from the client. Never a secret key.",
          "type": "string"
        },
        "currency": {
          "type": "string"
        },
        "deliveryBreakdown": {
          "description": "021: the per-package delivery breakdown, for the order summary. Anonymous.",
          "items": {
            "$ref": "#/definitions/DeliveryBreakdownLineDTO"
          },
          "type": "array"
        },
        "grandTotalAmount": {
          "type": "string"
        },
        "orderId": {
          "type": "string"
        },
        "orderNumber": {
          "type": "string"
        },
        "publishableKey": {
          "type": "string"
        }
      },
      "required": [
        "orderId",
        "orderNumber",
        "clientSecret",
        "publishableKey",
        "grandTotalAmount",
        "currency"
      ],
      "type": "object"
    },
    "DeliveryBreakdownLineDTO": {
      "additionalProperties": false,
      "description": "One line of the per-package delivery breakdown on the intent response (021). Anonymous.",
      "properties": {
        "feeAmount": {
          "type": "string"
        },
        "packageKey": {
          "type": "string"
        },
        "serviceLevel": {
          "type": "string"
        },
        "window": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "packageKey",
        "serviceLevel",
        "feeAmount",
        "window"
      ],
      "type": "object"
    },
    "DeliveryMethodOptionDTO": {
      "additionalProperties": false,
      "description": "One selectable delivery option for a package (021). Server-computed; the client never sends a fee.",
      "properties": {
        "feeAmount": {
          "type": "string"
        },
        "method": {
          "$ref": "#/definitions/CheckoutDeliveryMethod"
        },
        "scheduleDates": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "description": "Selectable dates for method='scheduled'; null otherwise."
        },
        "serviceLevel": {
          "description": "Customer-facing label, e.g. \"Same-day\".",
          "type": "string"
        },
        "window": {
          "description": "Derived window, e.g. \"Today by 6pm\" / \"in 2–3 days\"; null for a scheduled method (pick a date).",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "method",
        "serviceLevel",
        "feeAmount",
        "window",
        "scheduleDates"
      ],
      "type": "object"
    },
    "DeliveryQuoteRequest": {
      "additionalProperties": false,
      "description": "POST /v1/checkout/quote — per-package delivery options for the cart + address (021 US1).",
      "properties": {
        "addressId": {
          "type": "string"
        }
      },
      "required": [
        "addressId"
      ],
      "type": "object"
    },
    "DeliveryQuoteResponse": {
      "additionalProperties": false,
      "properties": {
        "expiresAt": {
          "description": "The captured quote is honored until this instant; after it the customer must re-quote (021 R7).",
          "type": "string"
        },
        "packages": {
          "items": {
            "$ref": "#/definitions/QuotePackageDTO"
          },
          "type": "array"
        },
        "quoteId": {
          "type": "string"
        }
      },
      "required": [
        "packages",
        "quoteId",
        "expiresAt"
      ],
      "type": "object"
    },
    "DeliverySelectionDTO": {
      "additionalProperties": false,
      "description": "The customer's chosen method for one package (021). Carries NO fee — the server prices it (SC-004).",
      "properties": {
        "method": {
          "$ref": "#/definitions/CheckoutDeliveryMethod"
        },
        "packageKey": {
          "type": "string"
        },
        "scheduledDate": {
          "description": "Required only when method='scheduled'.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "packageKey",
        "method"
      ],
      "type": "object"
    },
    "FavoriteDTO": {
      "additionalProperties": false,
      "description": "A saved product (product card fields + when it was saved).",
      "properties": {
        "available": {
          "type": "boolean"
        },
        "badges": {
          "items": {
            "$ref": "#/definitions/ProductBadge"
          },
          "type": "array"
        },
        "brand": {
          "type": [
            "string",
            "null"
          ]
        },
        "compareAtAmount": {
          "type": [
            "string",
            "null"
          ]
        },
        "currency": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "imageUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "priceAmount": {
          "type": "string"
        },
        "savedAt": {
          "type": "string"
        }
      },
      "required": [
        "available",
        "badges",
        "brand",
        "compareAtAmount",
        "currency",
        "id",
        "imageUrl",
        "name",
        "priceAmount",
        "savedAt"
      ],
      "type": "object"
    },
    "MediaDTO": {
      "additionalProperties": false,
      "description": "A product image (presigned GET URL + alt text).",
      "properties": {
        "alt": {
          "type": [
            "string",
            "null"
          ]
        },
        "imageUrl": {
          "type": "string"
        }
      },
      "required": [
        "imageUrl",
        "alt"
      ],
      "type": "object"
    },
    "MergeCartRequest": {
      "additionalProperties": false,
      "description": "POST /v1/cart/merge — merge a device-local guest cart on sign-in (sums qty per product).",
      "properties": {
        "lines": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "productId": {
                "type": "string"
              },
              "quantity": {
                "type": "number"
              }
            },
            "required": [
              "productId",
              "quantity"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "lines"
      ],
      "type": "object"
    },
    "OrderAddressDTO": {
      "additionalProperties": false,
      "description": "The snapshotted delivery address on the receipt.",
      "properties": {
        "city": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "line1": {
          "type": "string"
        },
        "line2": {
          "type": [
            "string",
            "null"
          ]
        },
        "phone": {
          "type": [
            "string",
            "null"
          ]
        },
        "postalCode": {
          "type": "string"
        },
        "recipientName": {
          "type": "string"
        },
        "region": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "recipientName",
        "phone",
        "line1",
        "line2",
        "city",
        "region",
        "postalCode",
        "country"
      ],
      "type": "object"
    },
    "OrderDTO": {
      "additionalProperties": false,
      "description": "Full order / receipt (GET /v1/orders/{id}).",
      "properties": {
        "billingAddress": {
          "anyOf": [
            {
              "$ref": "#/definitions/OrderAddressDTO"
            },
            {
              "type": "null"
            }
          ],
          "description": "The BILLING address snapshot (023). `null` means \"same as shipping\" — the client renders \"Billing: same as shipping\" rather than repeating the address. A value is a divergent billing address. NEVER exposed to the shop (FR-018). Absent/null on pre-023 orders."
        },
        "currency": {
          "type": "string"
        },
        "deliveryAddress": {
          "$ref": "#/definitions/OrderAddressDTO",
          "description": "The SHIPPING address snapshot (the main one — where the order is delivered)."
        },
        "deliveryFeeAmount": {
          "type": "string"
        },
        "fulfillments": {
          "items": {
            "$ref": "#/definitions/OrderFulfillmentDTO"
          },
          "type": "array"
        },
        "grandTotalAmount": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "itemSubtotalAmount": {
          "type": "string"
        },
        "items": {
          "items": {
            "$ref": "#/definitions/OrderItemDTO"
          },
          "type": "array"
        },
        "orderNumber": {
          "type": "string"
        },
        "paymentStatus": {
          "$ref": "#/definitions/PaymentStatus"
        },
        "placedAt": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/definitions/OrderStatus"
        }
      },
      "required": [
        "id",
        "orderNumber",
        "status",
        "placedAt",
        "items",
        "deliveryAddress",
        "itemSubtotalAmount",
        "deliveryFeeAmount",
        "grandTotalAmount",
        "currency",
        "paymentStatus",
        "fulfillments"
      ],
      "type": "object"
    },
    "OrderFulfillmentDTO": {
      "additionalProperties": false,
      "description": "An anonymous per-shop fulfillment portion — NO shop identity (FR-033).\n\n020 gave `status` a life: 019 created every portion `pending` and no code path ever changed it. The values now span the shop's real working lifecycle. Still no shop name, id, or count that would imply WHO is fulfilling (FR-018, SC-009).",
      "properties": {
        "deliveryFeeAmount": {
          "type": "string"
        },
        "deliveryServiceLevel": {
          "description": "The delivery this portion was bought with (021) — still ANONYMOUS (no shop). The customer's receipt breakdown shows, per package, what they paid to have it delivered and when it is promised. Absent on pre-021 orders.",
          "type": "string"
        },
        "deliveryWindow": {
          "type": [
            "string",
            "null"
          ]
        },
        "itemCount": {
          "type": "number"
        },
        "status": {
          "enum": [
            "pending",
            "received",
            "picking",
            "ready_for_pickup",
            "collected",
            "delivered"
          ],
          "type": "string"
        },
        "subtotalAmount": {
          "type": "string"
        },
        "unavailableItems": {
          "description": "Present ONLY when the portion has reached a terminal state (FR-018b). Absent while picking.",
          "items": {
            "$ref": "#/definitions/OrderShortfallDTO"
          },
          "type": "array"
        }
      },
      "required": [
        "status",
        "itemCount",
        "subtotalAmount"
      ],
      "type": "object"
    },
    "OrderItemDTO": {
      "additionalProperties": false,
      "description": "A line on the receipt (product snapshot — never a shop).",
      "properties": {
        "lineSubtotalAmount": {
          "type": "string"
        },
        "productId": {
          "type": "string"
        },
        "productName": {
          "type": "string"
        },
        "quantity": {
          "type": "number"
        },
        "unitPriceAmount": {
          "type": "string"
        }
      },
      "required": [
        "productId",
        "productName",
        "unitPriceAmount",
        "quantity",
        "lineSubtotalAmount"
      ],
      "type": "object"
    },
    "OrderShortfallDTO": {
      "additionalProperties": false,
      "description": "An item the customer paid for and will NOT receive (020 FR-018b).\n\nDisclosed at item level, but ONLY once the portion is terminal — a flag raised and then undone mid-pick must never reach the customer (SC-017). Naming the customer's own item discloses nothing about fulfillment structure (FR-018c).\n\nCarries NO refund promise: no money moves in 020, and the shortfall is left deliberately visible for a later refunds slice to resolve (FR-010b, FR-018a).",
      "properties": {
        "productName": {
          "type": "string"
        },
        "quantity": {
          "type": "number"
        }
      },
      "required": [
        "productName",
        "quantity"
      ],
      "type": "object"
    },
    "OrderStatus": {
      "description": "Order lifecycle mirrored to the client (payment-driven).",
      "enum": [
        "pending_payment",
        "paid",
        "failed",
        "canceled"
      ],
      "type": "string"
    },
    "OrderSummaryDTO": {
      "additionalProperties": false,
      "description": "A row in the order history (GET /v1/orders).",
      "properties": {
        "currency": {
          "type": "string"
        },
        "grandTotalAmount": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "itemCount": {
          "type": "number"
        },
        "orderNumber": {
          "type": "string"
        },
        "placedAt": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "$ref": "#/definitions/OrderStatus"
        }
      },
      "required": [
        "id",
        "orderNumber",
        "status",
        "placedAt",
        "itemCount",
        "grandTotalAmount",
        "currency"
      ],
      "type": "object"
    },
    "PaymentStatus": {
      "description": "Payment outcome mirrored from the Stripe PaymentIntent.",
      "enum": [
        "requires_payment",
        "requires_action",
        "succeeded",
        "failed",
        "canceled"
      ],
      "type": "string"
    },
    "ProductAttributeGroupDTO": {
      "additionalProperties": false,
      "description": "A labelled group of attribute rows on the product detail page (never laid out as cards).",
      "properties": {
        "groupLabel": {
          "type": "string"
        },
        "items": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "label": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            },
            "required": [
              "label",
              "value"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "groupLabel",
        "items"
      ],
      "type": "object"
    },
    "ProductBadge": {
      "description": "A badge shown on a product card. Derived server-side (on_sale = has compare-at; new = newest).",
      "enum": [
        "on_sale",
        "new"
      ],
      "type": "string"
    },
    "ProductSearchResultDTO": {
      "additionalProperties": false,
      "description": "A page of search results with a keyset cursor for infinite scroll.",
      "properties": {
        "items": {
          "items": {
            "$ref": "#/definitions/StorefrontProductCardDTO"
          },
          "type": "array"
        },
        "nextCursor": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "items",
        "nextCursor"
      ],
      "type": "object"
    },
    "QuotePackageDTO": {
      "additionalProperties": false,
      "properties": {
        "items": {
          "items": {
            "$ref": "#/definitions/QuotePackageItemDTO"
          },
          "type": "array"
        },
        "methods": {
          "items": {
            "$ref": "#/definitions/DeliveryMethodOptionDTO"
          },
          "type": "array"
        },
        "packageKey": {
          "type": "string"
        },
